DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=finance_app
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=personal-finance-api
JWT_AUDIENCE=personal-finance-app
JWT_TTL=172800

APP_PIN=1234
# Preferred for production: set APP_PIN_HASH instead of APP_PIN.
# Generate one with: php -r "echo password_hash('1234', PASSWORD_DEFAULT);"
APP_PIN_HASH=
PIN_REMEMBER_HOURS=48

CORS_ALLOWED_ORIGINS=http://192.168.0.222:5173
